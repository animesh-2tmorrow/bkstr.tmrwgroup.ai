// bkstr.tmrwgroup.ai — Prisma schema
// Phase 1 scaffold: multi-tenant publisher/book/subscriber model.
// No eval tables yet (deferred until Edward confirms eval depth).

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────────

enum BookStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum SubscriptionTier {
  STARTER
  GROWTH
  ENTERPRISE
}

// Phase 3 (D9.1) — role on User. SUBSCRIBER is the default for OAuth signups
// per events.createUser; PUBLISHER and ADMIN are operator-promoted.
enum Role {
  SUBSCRIBER
  PUBLISHER
  ADMIN
}

// Phase 3 (D9.6) — provenance of an access_grants row. SEED grandfathers
// pre-Phase-3 implicit access; SUBSCRIPTION/PURCHASE created by Stream 3
// Stripe webhooks; MANUAL by admin/operator action. Phase 4 (D11.3) adds
// PUBLISHER_OWN for publishers' auto-grants on their own books (CC-3).
enum GrantSource {
  MANUAL
  SUBSCRIPTION
  PURCHASE
  SEED
  PUBLISHER_OWN
}

// ─────────────────────────────────────────────────────────────────────────────
// Publishers
// Multi-tenant root. Seed at Step 5 with `tmrwgroup` and `etumos`.
// ─────────────────────────────────────────────────────────────────────────────

model Publisher {
  id        String   @id @default(uuid()) @db.Uuid
  slug      String   @unique @db.VarChar(64)
  name      String   @db.VarChar(255)
  createdAt DateTime @default(now()) @map("created_at")

  books Book[]

  @@map("publishers")
}

// ─────────────────────────────────────────────────────────────────────────────
// Books
// A "book" is a compressed knowledge artifact owned by a publisher.
// Domain is a free-text categorization tag for now (Marketing Ops, QA, etc.).
// Versions live in book_versions; the latest active version is the served one.
// ─────────────────────────────────────────────────────────────────────────────

model Book {
  id              String     @id @default(uuid()) @db.Uuid
  publisherId     String     @map("publisher_id") @db.Uuid
  // Phase 4 (D11.10) — per-user publisher attribution. Nullable for staged
  // authoring: at migration time Edward + Zach may not have signed in yet,
  // and #68 tracks tightening this to NOT NULL once every existing book row
  // has a non-null value. Paired with `description` for the same reason.
  publisherUserId String?    @map("publisher_user_id") @db.Uuid
  slug            String     @db.VarChar(128)
  title           String     @db.VarChar(255)
  // Phase 4 (D11.10) — long-form prose description. Nullable for staged
  // authoring; tighten alongside #68 if/when the invariant becomes
  // "every book has prose description." Stream B (publisher UI) writes this
  // on new-book creation; existing 5 books backfill as NULL.
  description     String?    @db.Text
  domain          String     @db.VarChar(64)
  status          BookStatus @default(DRAFT)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  publisher     Publisher     @relation(fields: [publisherId], references: [id], onDelete: Cascade)
  publisherUser User?         @relation("BookPublisher", fields: [publisherUserId], references: [id], onDelete: SetNull)
  versions      BookVersion[]
  prices        BookPrice[]
  accessGrants  AccessGrant[]

  @@unique([publisherId, slug])
  @@index([status])
  @@index([domain])
  @@index([publisherUserId])
  @@map("books")
}

// ─────────────────────────────────────────────────────────────────────────────
// Book Versions
// Append-only version chain. content_uri points to S3 in v1; placeholder
// `s3://bkstr-books-placeholder/...` is acceptable for Phase 1.
// ─────────────────────────────────────────────────────────────────────────────

model BookVersion {
  id         String   @id @default(uuid()) @db.Uuid
  bookId     String   @map("book_id") @db.Uuid
  version    Int
  contentUri String   @map("content_uri") @db.Text
  byteSize   Int      @map("byte_size")
  content    String?  @db.Text
  createdAt  DateTime @default(now()) @map("created_at")

  book      Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  fetchLogs FetchLog[]

  @@unique([bookId, version])
  @@index([bookId, createdAt])
  @@map("book_versions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Auth (NextAuth v4 + @next-auth/prisma-adapter)
// User = identity (email, name, image, OAuth provider linkage).
// Account = per-provider OAuth tokens (one User can link multiple providers).
// Session = active database-backed session (revocable, listable).
// VerificationToken = magic-link / email verification challenge (kept for
//   future magic-link enable; Phase 2 is Google-only — see decision log D1).
// All four tables follow Phase 1's snake_case @@map convention.
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(uuid()) @db.Uuid
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  name          String?
  image         String?
  role          Role      @default(SUBSCRIBER)
  // Phase 4.5 Stream H (D12.3) — most-recent successful signin timestamp.
  // Written by src/lib/auth/index.ts's events.signIn + events.createUser
  // hooks on every signin (both new-user and returning-user paths).
  //
  // Nullable for the deploy-day initial state: existing user rows have no
  // historical signin time to derive — the sessions table has no created_at
  // column (verified at prisma/migrations/20260508120000_add_nextauth_tables
  // /migration.sql:36-43 — sessions rows carry only id, session_token,
  // user_id, expires) and the accounts.updated_at heuristic is unreliable
  // (the PrismaAdapter does not bump it on signin). No backfill — existing
  // 3 users are NULL until each one signs in after this column ships.
  //
  // Indexed (single-column DESC) so Stream E's `ORDER BY last_signin_at
  // DESC NULLS LAST` admin users-list runs efficiently. Read consumer is
  // Stream E's getAdminUsers() / /dashboard/admin/users surface; Stream E
  // renders NULL as "—" until the column populates for each user.
  lastSigninAt  DateTime? @map("last_signin_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  accounts       Account[]
  sessions       Session[]
  subscriber     Subscriber?
  grantedAccess  AccessGrant[] @relation("AccessGrantGrantor")
  // Phase 4 (D11.10) — inverse of Book.publisherUser. A User's published books
  // are surfaced via this relation in /dashboard/pricing (PUBLISHER scope filter)
  // and Stream B's new-book creation. ON DELETE SET NULL preserves the books
  // independent of the publisher's User row.
  publishedBooks Book[]        @relation("BookPublisher")
  // Phase 4.5 Stream G (D12.7) — inverse of AdminAction.actor. Durable audit
  // trail of every ADMIN mutation this user performed (role changes, book
  // ownership reassignment, access_grants revoke). ON DELETE RESTRICT on the
  // owning side preserves history — a User with audit rows cannot be hard-
  // deleted without an explicit operator migration.
  adminActions   AdminAction[] @relation("AdminActionActor")

  @@index([lastSigninAt(sort: Desc)])
  @@map("users")
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @map("user_id") @db.Uuid
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id") @db.Uuid
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─────────────────────────────────────────────────────────────────────────────
// Subscribers
// Companies that consume books via API for their internal agent fleets.
// Each Subscriber maps 1:1 to a User in Phase 2 (unique constraint on user_id);
// future phases relax this to many-to-many. user_id is nullable so Phase 1
// pre-existing Subscriber rows (none yet) survive the migration; new signups
// always populate it via the NextAuth signIn callback.
// ─────────────────────────────────────────────────────────────────────────────

model Subscriber {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String?  @unique @map("user_id") @db.Uuid
  companyName String   @map("company_name") @db.VarChar(255)
  email       String   @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at")

  user          User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  apiKeys       SubscriberApiKey[]
  subscriptions Subscription[]
  fetchLogs     FetchLog[]
  accessGrants  AccessGrant[]

  @@index([email])
  @@map("subscribers")
}

// ─────────────────────────────────────────────────────────────────────────────
// Subscriber API Keys
// Hash-only storage. Plaintext key returned at issuance only, never persisted.
// `key_prefix` retains the first ~8 characters of the plaintext (e.g. "bks_abc1")
// so operators can identify a key in the UI without ever seeing the rest.
// ─────────────────────────────────────────────────────────────────────────────

model SubscriberApiKey {
  id           String    @id @default(uuid()) @db.Uuid
  subscriberId String    @map("subscriber_id") @db.Uuid
  name         String    @default("") @db.Text
  keyHash      String    @unique @map("key_hash") @db.VarChar(128)
  keyPrefix    String    @map("key_prefix") @db.VarChar(16)
  lastUsedAt   DateTime? @map("last_used_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  fetchLogs  FetchLog[]

  @@index([subscriberId])
  @@index([keyPrefix])
  @@map("subscriber_api_keys")
}

// ─────────────────────────────────────────────────────────────────────────────
// Subscriptions
// Tier + status pair for billing. Pricing is placeholder; no Stripe linkage
// yet (the prompt's locked decision: Stripe SDK installed, no live calls).
// `status` is a free-text string in Phase 1 — values aren't yet specified
// (TRIALING, ACTIVE, PAST_DUE, CANCELED are the likely set).
// ─────────────────────────────────────────────────────────────────────────────

model Subscription {
  id           String           @id @default(uuid()) @db.Uuid
  subscriberId String           @map("subscriber_id") @db.Uuid
  tier         SubscriptionTier
  status       String           @db.VarChar(32)
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId])
  @@map("subscriptions")
}

// ─────────────────────────────────────────────────────────────────────────────
// Fetch Logs
// One row per agent-endpoint Bedrock invocation. Captures metadata + the
// query string. Response bodies are NEVER persisted (D3.3). Token counts
// and latency are nullable so error rows carry honest NULLs rather than
// sentinel zeros. status is free-form TEXT today (success/error/timeout);
// will enum-ize in Phase 3 once values stabilize (follow-up #20).
// No retention policy at internal-alpha (follow-up #19).
// ─────────────────────────────────────────────────────────────────────────────

model FetchLog {
  id            String   @id @default(uuid()) @db.Uuid
  subscriberId  String   @map("subscriber_id") @db.Uuid
  bookVersionId String   @map("book_version_id") @db.Uuid
  // Phase 4 (D11.12) — nullable to support Stream C dashboard surfaces
  // (View, Download) which run with a session cookie, no API key in play.
  // Existing agent_fetch rows continue to write a non-null apiKeyId.
  apiKeyId      String?  @map("api_key_id") @db.Uuid
  model         String   @db.Text
  query         String   @db.Text
  inputTokens   Int?     @map("input_tokens")
  outputTokens  Int?     @map("output_tokens")
  latencyMs     Int?     @map("latency_ms")
  status        String   @db.Text
  errorMessage  String?  @map("error_message") @db.Text
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  // Phase 4 (D11.13) — provenance of the row. Default `agent_fetch` matches
  // the existing /api/agent/fetch handler; Stream C surfaces will write
  // `dashboard_view` / `dashboard_download`. VARCHAR(32) + app-side
  // discipline (no Postgres enum) per the webhook_events.source precedent
  // (D9.3); future Stream C consumers may add values without a migration.
  source        String   @default("agent_fetch") @map("source") @db.VarChar(32)

  subscriber  Subscriber        @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  bookVersion BookVersion       @relation(fields: [bookVersionId], references: [id], onDelete: Restrict)
  apiKey      SubscriberApiKey? @relation(fields: [apiKeyId], references: [id], onDelete: Restrict)

  @@index([subscriberId, createdAt(sort: Desc)])
  @@index([bookVersionId])
  @@index([apiKeyId, createdAt(sort: Desc)])
  @@map("fetch_logs")
}

// ─────────────────────────────────────────────────────────────────────────────
// Access Grants (Phase 3, D9.6)
// Per-book authorization. SEED grants grandfather pre-Phase-3 implicit access;
// SUBSCRIPTION/PURCHASE rows are written by Stream 3's Stripe webhook handler;
// MANUAL by operator/admin action. The route's authorization check (deferred
// to a follow-up patch behind ENFORCE_BOOK_ACCESS env flag) reads from this
// table. Soft-delete via revoked_at; expires_at nullable means "no expiry."
// ─────────────────────────────────────────────────────────────────────────────

model AccessGrant {
  id                    String      @id @default(uuid()) @db.Uuid
  subscriberId          String      @map("subscriber_id") @db.Uuid
  bookId                String      @map("book_id") @db.Uuid
  source                GrantSource
  stripeSubscriptionId  String?     @map("stripe_subscription_id") @db.VarChar(64)
  stripePaymentIntentId String?     @map("stripe_payment_intent_id") @db.VarChar(64)
  grantedAt             DateTime    @default(now()) @map("granted_at")
  expiresAt             DateTime?   @map("expires_at")
  revokedAt             DateTime?   @map("revoked_at")
  grantedBy             String?     @map("granted_by") @db.Uuid

  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  book       Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  grantor    User?      @relation("AccessGrantGrantor", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([subscriberId, bookId, source])
  @@index([subscriberId, bookId])
  @@index([stripeSubscriptionId])
  @@map("access_grants")
}

// ─────────────────────────────────────────────────────────────────────────────
// Book Prices (Phase 3, D9.7)
// Per-book one-time price. UPDATE-in-place; price history NOT preserved at
// schema level — Stripe Price objects are immutable and serve as the
// system-of-record. Single-currency-USD at Phase 3 with currency CHAR(3)
// shape future-proofing for multi-currency in a later phase.
// ─────────────────────────────────────────────────────────────────────────────

model BookPrice {
  id              String   @id @default(uuid()) @db.Uuid
  bookId          String   @map("book_id") @db.Uuid
  currency        String   @default("USD") @db.Char(3)
  unitAmountCents Int      @map("unit_amount_cents")
  stripePriceId   String?  @unique @map("stripe_price_id") @db.VarChar(64)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([bookId, currency])
  @@map("book_prices")
}

// ─────────────────────────────────────────────────────────────────────────────
// Webhook Events (Phase 3, D9.3)
// Idempotency table for inbound webhooks. event_id is the natural primary key
// (Stripe's evt_… strings are globally unique). source discriminator lets the
// table cover Stream 3 (stripe) and any future Stream 2 (s3 SNS notifications)
// without parallel schemas. Insert pattern: INSERT … ON CONFLICT (event_id)
// DO NOTHING RETURNING event_id — empty result means duplicate.
// ─────────────────────────────────────────────────────────────────────────────

model WebhookEvent {
  eventId      String    @id @map("event_id") @db.VarChar(128)
  source       String    @db.VarChar(32)
  receivedAt   DateTime  @default(now()) @map("received_at")
  processedAt  DateTime? @map("processed_at")
  status       String    @db.VarChar(32)
  errorMessage String?   @map("error_message") @db.Text

  @@index([source, receivedAt(sort: Desc)])
  @@map("webhook_events")
}

// ─────────────────────────────────────────────────────────────────────────────
// Admin Actions (Phase 4.5 Stream G, D12.7)
// Durable audit trail of ADMIN mutations: user role changes (Stream E),
// book ownership reassignment + access_grants revoke (Stream F). Write
// surface only in Phase 4.5; read surface (/dashboard/admin/audit) deferred
// per D12.12 — operators query this table via psql until the read surface
// ships.
//
// Schema choices (D12.7):
//   - VARCHAR(64) / VARCHAR(32) discriminator strings (NOT Postgres enums)
//     per the webhook_events.source precedent (D9.3) — future action types
//     and target types ship without schema migrations.
//   - JSONB for before/after state captures CHANGING FIELDS ONLY (D12.14),
//     not full row snapshots. Forensically adequate; storage-efficient.
//   - actor_user_id FK with ON DELETE RESTRICT — preserves history;
//     deleting a User that still has audit rows is blocked at the DB layer.
//   - No FK on target_id — target is polymorphic across users/books/
//     access_grants. App-side discipline via the target_type discriminator.
//   - Three composite indexes pre-aligned with the eventual read surface's
//     three filter dimensions (actor, target, action type).
//
// actionType convention (D12.5): dot-delimited `<scope>.<verb>[_<qualifier>]`.
//   user.role_promote_admin, user.role_promote_publisher,
//   user.role_demote_subscriber, user.role_demote_publisher,
//   book.reassign_publisher, grant.revoke.
// ─────────────────────────────────────────────────────────────────────────────

model AdminAction {
  id          String   @id @default(uuid()) @db.Uuid
  actorUserId String   @map("actor_user_id") @db.Uuid
  actionType  String   @map("action_type") @db.VarChar(64)
  targetType  String   @map("target_type") @db.VarChar(32)
  targetId    String   @map("target_id") @db.Uuid
  beforeState Json?    @map("before_state") @db.JsonB
  afterState  Json?    @map("after_state") @db.JsonB
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  actor User @relation("AdminActionActor", fields: [actorUserId], references: [id], onDelete: Restrict, onUpdate: Cascade)

  @@index([actorUserId, createdAt(sort: Desc)])
  @@index([targetType, targetId, createdAt(sort: Desc)])
  @@index([actionType, createdAt(sort: Desc)])
  @@map("admin_actions")
}
