# bkstr.tmrwgroup.ai — environment variables (template)
#
# Copy to .env (gitignored) for local development. In production these are
# staged on EC2 across multiple files (D9.4 per-service env-file convention):
#   /var/www/bkstr/.env      DATABASE_URL only, rsync-preserved across deploys.
#   /etc/bkstr/oauth.env     GOOGLE_*, NEXTAUTH_* (operator-staged, 600 root).
#   /etc/bkstr/aws.env       AWS_REGION, BKSTR_CONTENT_BUCKET (operator-staged, 600 root).
#   /etc/bkstr/stripe.env    STRIPE_* (operator-staged, 600 root).
#   /etc/bkstr/roles.env     ADMIN_EMAILS, PUBLISHER_EMAILS (operator-staged, 600 root; D11.5–D11.6).
# start.sh sources each present file before pm2 reload --update-env.
#
# Never commit real values from this file — generate fresh ones per
# environment, especially NEXTAUTH_SECRET and the OAuth client secret.

# ─── Database ──────────────────────────────────────────────────────────────
# Postgres connection string (Prisma).
# `?schema=public` is required by Prisma's driver-adapter; raw psql does NOT
# accept that query param — strip it for direct psql access (#47).
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public

# ─── Google OAuth ──────────────────────────────────────────────────────────
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs must include http://localhost:3000/api/auth/callback/google
# (dev) and https://your-prod-host/api/auth/callback/google (prod).
GOOGLE_CLIENT_ID=REPLACE-WITH-GOOGLE-CLIENT-ID
GOOGLE_CLIENT_SECRET=REPLACE-WITH-GOOGLE-CLIENT-SECRET

# ─── NextAuth ──────────────────────────────────────────────────────────────
# Must match the deployed origin (no trailing slash).
NEXTAUTH_URL=https://your-deployed-host

# Session encryption key. Generate a fresh value per environment with:
#   openssl rand -base64 32
# Never commit a real value.
NEXTAUTH_SECRET=REPLACE-WITH-OPENSSL-RAND-BASE64-32

# ─── Role-grant lists (Phase 4 Stream D — D9.4 / D10.3 / D11.5 / D11.6 / D11.11) ─
# Operator-staged in /etc/bkstr/roles.env on EC2 (mode 600 root) per the
# per-service env-file convention (D9.4); sourced by scripts/start.sh under
# its own [ -f /etc/bkstr/roles.env ] && source ... block above the D10.3
# marker. Local dev: drop into your local .env.
#
# Semantics (D11.11 — MONOTONIC-UPWARD, hard safety invariant):
#   - Env presence PROMOTES. An email in ADMIN_EMAILS gets users.role=ADMIN;
#     an email in PUBLISHER_EMAILS (and not in ADMIN_EMAILS) gets PUBLISHER.
#   - Env absence is a NO-OP. Unset or empty env vars NEVER demote existing
#     ADMINs / PUBLISHERs. Demotion is operator-explicit only, via
#     `UPDATE users SET role='SUBSCRIBER' WHERE email='…'` (see docs/operations.md
#     "Roles env file" runbook). Removing an email from PUBLISHER_EMAILS is NOT
#     a demotion path.
#   - The role-sync hook in src/lib/auth/index.ts runs on EVERY signin (not
#     just first signin), so adding an email here promotes the user on their
#     next visit without re-deploys beyond `pm2 reload --update-env`.
#   - Precedence: if a single email appears in BOTH lists, ADMIN wins.
#
# Pre-deploy operator action (D11.5): /etc/bkstr/roles.env MUST be staged
# before the first signin under this code path, or new users land at the
# schema default (SUBSCRIBER) with no auto-promotion. Existing ADMINs are
# preserved regardless (monotonic-upward never demotes).
#
# ADMIN_EMAILS — comma-separated, lowercase, full email. Identities granted
# users.role=ADMIN on signin. Example: animesh@2tmorrow.com
ADMIN_EMAILS=

# PUBLISHER_EMAILS — comma-separated, lowercase, full email. Identities
# granted users.role=PUBLISHER on signin (unless also in ADMIN_EMAILS).
# Example: edward@tmrwgroup.ai,zach@tmrwgroup.ai
PUBLISHER_EMAILS=

# ─── AWS / S3 (Phase 3 D9.2 + D9.4) ─────────────────────────────────────────
# Staged on EC2 in /etc/bkstr/aws.env (mode 600 root), sourced by start.sh.
# No AWS_ACCESS_KEY_ID / AWS_SECRET_ACCESS_KEY here — instance-profile
# credentials (bkstr-ec2-role) are auto-discovered via IMDSv2; access keys
# in env would override the instance profile and break the auth model.
#
# AWS_REGION — region for both Bedrock (today hardcoded in src/lib/bedrock.ts;
# harmonization deferred per Stream 2 OQ-8) and S3 book content storage.
AWS_REGION=us-east-1

# BKSTR_CONTENT_BUCKET — S3 bucket holding migrated book_versions content
# under keys books/<book_id>/versions/<book_version_id>.md.
# Format: bkstr-book-content-<account_id>-<region>
BKSTR_CONTENT_BUCKET=bkstr-book-content-049405321468-us-east-1

# ─── Stripe (Phase 3 Stream 3 — D9.5 / D10.3) ──────────────────────────────
# Operator-staged in /etc/bkstr/stripe.env (mode 600 root) on EC2 — start.sh
# sources it before pm2 reload. Local dev: drop into your local .env. Test
# mode keys (sk_test_…, pk_test_…, whsec_…) are fine for everything except
# the production live cutover.
#
# STRIPE_SECRET_KEY: backend-only. Stripe Dashboard → Developers → API keys.
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_STRIPE_SECRET

# STRIPE_PUBLISHABLE_KEY: client-side, ok to ship. Currently unused (Hosted
# Checkout per OQ-2 doesn't need it on the client) but staged for any future
# Stripe Elements work.
STRIPE_PUBLISHABLE_KEY=pk_test_REPLACE_WITH_STRIPE_PUBLISHABLE

# STRIPE_WEBHOOK_SECRET: per-endpoint, generated by Stripe Dashboard →
# Developers → Webhooks → <endpoint>. Used by stripe.webhooks.constructEvent
# in src/app/api/webhooks/stripe/route.ts. Each environment (test/live) has
# its own endpoint and its own secret — do NOT reuse across environments.
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SIGNING_SECRET
